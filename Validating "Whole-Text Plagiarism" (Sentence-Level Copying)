# A mathematically rigorous word-level edit distance function
verify_copy_word_level <- function(text_a, text_b) {
  # 1. Clean whitespace and split text into words
  words_a <- unlist(strsplit(gsub("\\s+", " ", text_a), " "))
  words_b <- unlist(strsplit(gsub("\\s+", " ", text_b), " "))
  
  # Extract all unique words across both texts
  unique_words <- unique(c(words_a, words_b))
  
  # Map each unique word to a strict single-byte character representation
  # to preserve metric distance axioms in adist()
  map_to_char <- function(words, dict) {
    match_idx <- match(words, dict)
    rawToChar(as.raw(match_idx + 32)) # Offset to avoid control characters
  }
  
  encoded_a <- map_to_char(words_a, unique_words)
  encoded_b <- map_to_char(words_b, unique_words)
  
  # 2. Compute Levenshtein distance on words using Base R's adist()
  edit_dist <- as.numeric(adist(encoded_a, encoded_b))
  
  # 3. Normalize into a similarity score [0, 1]
  max_len <- max(length(words_a), length(words_b))
  similarity <- 1 - (edit_dist / max_len)
  
  return(list(word_distance = edit_dist, similarity = similarity))
}

# --- Validation ---
text1 <- "The quick brown fox jumps over the lazy dog"
text2 <- "The quick brown fox leaps over the lazy dog"  # 1 word substituted
text3 <- "lazy dog over the jumps fox brown quick The"  # Shuffled words

verify_copy_word_level(text1, text2)$similarity  # Result: ~0.89 (High similarity = Suspected Plagiarism)
verify_copy_word_level(text1, text3)$similarity  # Result: ~0.22 (Low similarity = Scrambled word order caught)
